        </mxCell>
        <mxCell id="p7p0e" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;fontSize=11;arcSize=10;" value="&lt;b&gt;stream.state → &#39;running&#39;&lt;/b&gt;&lt;br/&gt;Обновляется при&lt;br/&gt;первом batch" vertex="1">
