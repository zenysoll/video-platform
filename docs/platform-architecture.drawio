        <mxCell id="p7p0d" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#6b7280;fontSize=11;arcSize=10;" value="&lt;b&gt;CF Queue принял&lt;/b&gt;&lt;br/&gt;Сообщение в очереди&lt;br/&gt;Consumer запустится&lt;br/&gt;в течение секунд" vertex="1">
