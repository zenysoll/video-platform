        <mxCell id="p7p0f" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=11;arcSize=10;" value="&lt;b&gt;GPU арендуется&lt;/b&gt;&lt;br/&gt;Vast.ai API: create instance&lt;br/&gt;vast_instance_id=&#39;pending&#39;&lt;br/&gt;→ &#39;35088xxx&#39;" vertex="1">
