        <mxCell id="p4s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#d97706;fontSize=10;arcSize=4;verticalAlign=middle;" value="Cold start + bootstrap (~26-28 мин)" vertex="1">
          <mxGeometry height="60" width="682.0666666666667" x="92.46666666666667" y="305" as="geometry" />
        </mxCell>
        <mxCell id="p4s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=10;arcSize=4;verticalAlign=middle;" value="Загрузка VRAM (~5 мин)" vertex="1">
          <mxGeometry height="60" width="157.4" x="774.5333333333333" y="305" as="geometry" />
        </mxCell>
        <mxCell id="p4s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#16a34a;fontSize=10;arcSize=4;verticalAlign=middle;" value="Генерация (каждые ~2-5 мин × N видео)" vertex="1">
          <mxGeometry height="60" width="682.0666666666667" x="931.9333333333333" y="305" as="geometry" />
        </mxCell>
        <mxCell id="p4n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#ef4444;fontSize=11;arcSize=6;" value="⚠️ &lt;b&gt;Зачем wait_for_comfyui()?&lt;/b&gt;&lt;br/&gt;До фикса: worker.py стартовал сразу после bootstrap. ComfyUI принимал TCP, но ещё грузил модель в VRAM.&lt;br/&gt;Результат: &lt;urlopen error: write operation timed out&gt; — потеря render_attempts, job не отрендерен.&lt;br/&gt;После фикса: worker.py поллит GET /queue каждые 5с до 200 OK (до 10 мин), и только потом клеймит первый job." vertex="1">
          <mxGeometry height="115" width="770" x="40" y="395" as="geometry" />
        </mxCell>
        <mxCell id="p4n2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=11;arcSize=6;" value="💡 &lt;b&gt;R2 vs HuggingFace для загрузки модели&lt;/b&gt;&lt;br/&gt;R2 (Cloudflare): ~500 MB/s → 46 ГБ за ~1.5 мин 🚀&lt;br/&gt;HuggingFace fallback: ~11 MB/s → 46 ГБ за ~70 мин 🐌&lt;br/&gt;Всегда используем R2 как основной источник." vertex="1">
          <mxGeometry height="95" width="770" x="840" y="395" as="geometry" />
        </mxCell>
        <mxCell id="p4n3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;fontSize=11;arcSize=6;" value="🖥️ &lt;b&gt;Требования к GPU-инстансу (фильтр Vast.ai)&lt;/b&gt;&lt;br/&gt;VRAM ≥ 30 ГБ (RTX 5090 = 32 ГБ)  |  RAM ≥ 48 ГБ&lt;br/&gt;Disk ≥ 120 ГБ  |  Inet ≥ 500 Mbps  |  Reliability ≥ 0.98&lt;br/&gt;GPU: предпочтение RTX 5090 (Blackwell sm_120 — требует PyTorch nightly cu128)" vertex="1">
          <mxGeometry height="110" width="770" x="40" y="530" as="geometry" />
        </mxCell>
        <mxCell id="p4n4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;fontSize=11;arcSize=6;" value="🔮 &lt;b&gt;Оптимизация: pre-built Docker image&lt;/b&gt;&lt;br/&gt;Сейчас: базовый pytorch образ + bootstrap = ~25-30 мин cold start.&lt;br/&gt;Pre-built image с PyTorch+ComfyUI+нодами: cold start сократится до ~5-7 мин.&lt;br/&gt;Экономит ~20 мин аренды и $0.5–1 на каждый стрим." vertex="1">
          <mxGeometry height="115" width="770" x="840" y="510" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
