        </mxCell>
        <mxCell id="p6b2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;fontSize=11;arcSize=10;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;computeFingerprint(brief)&lt;/b&gt;&lt;br&gt;src/prompts/fingerprint.ts&lt;br&gt;SHA-256 хэш четырёх ключевых полей: theme + subject + action + camera&lt;br&gt;Нормализация: lowercase + trim + collapse spaces&lt;br&gt;canonical = &#39;theme|subject|action|camera&#39; → sha256hex&lt;br&gt;Почему 4 поля, а не все 8?&lt;br&gt;Environment и lighting варьируются естественно — позволяем одну сцену в разном освещении.&lt;br&gt;Theme + subject + action + camera определяют визуальную идентичность сцены.&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="1440" x="820" y="10" as="geometry" />
        </mxCell>
        <mxCell id="p6b3a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#6b7280;fontSize=11;arcSize=10;" value="&lt;b&gt;isDuplicate(db, fingerprint)&lt;/b&gt;&lt;br/&gt;SELECT 1 FROM prompt_fingerprints WHERE fingerprint = ?&lt;br/&gt;Проверка по D1 SQLite&lt;br/&gt;&lt;br/&gt;Если найдено → REROLL (попытка +1)" vertex="1">
          <mxGeometry height="110" width="520" x="-540" y="90" as="geometry" />
        </mxCell>
        <mxCell id="p6b3b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#6b7280;fontSize=11;arcSize=10;" value="&lt;b&gt;Batch-check&lt;/b&gt;&lt;br/&gt;results.some(r =&gt; r.fingerprint === fp)&lt;br/&gt;Проверка внутри текущего батча&lt;br/&gt;&lt;br/&gt;Предотвращает дубли между видео&lt;br/&gt;одного батча (D1 ещё не обновлён)" vertex="1">
          <mxGeometry height="110" width="520" x="940" y="250" as="geometry" />
        </mxCell>
        <mxCell id="p6b3c" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#6b7280;fontSize=11;arcSize=10;" value="&lt;b&gt;avoidThemes tracking&lt;/b&gt;&lt;br/&gt;usedThemes.push(theme/subject)&lt;br/&gt;при каждом принятом промпте&lt;br/&gt;&lt;br/&gt;Плановщик получает список в след. итерации →&lt;br/&gt;3-уровневая защита от дублей" vertex="1">
          <mxGeometry height="110" width="370" x="1490" y="250" as="geometry" />
        </mxCell>
        <mxCell id="ttNDG6qITpcUieB05yGR-1" edge="1" parent="1" source="p6b4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p6b6" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p6b4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#a855f7;fontSize=11;arcSize=10;" value="&lt;b&gt;renderPrompt(brief, durationSecs)&lt;/b&gt;&lt;br/&gt;src/prompts/renderer.ts&lt;br/&gt;&lt;br/&gt;Gemini API — temperature=0.7 (стабильнее, меньше галлюцинаций)&lt;br/&gt;System prompt: правила LTX-2.3 (present tense, active voice, &lt;120 слов, без &#39;AI/generated/video&#39;)&lt;br/&gt;Передаёт все 8 полей brief + duration_secs → один плотный абзац на английском&lt;br/&gt;Пример: &#39;A young woman walks along a rooftop edge at night, arms outstretched, city lights glowing below...&#39;" vertex="1">
          <mxGeometry height="110" width="1440" x="-1120" y="500" as="geometry" />
        </mxCell>
        <mxCell id="p6b5a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#ef4444;fontSize=11;arcSize=10;" value="&lt;b&gt;validateLength(promptText)&lt;/b&gt;&lt;br/&gt;Синхронная проверка (без LLM)&lt;br/&gt;Минимум / максимум символов&lt;br/&gt;Если не OK → REROLL" vertex="1">
          <mxGeometry height="100" width="340" x="470" y="740" as="geometry" />
        </mxCell>
        <mxCell id="p6b5b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#ef4444;fontSize=11;arcSize=10;" value="&lt;b&gt;validatePrompt(promptText)&lt;/b&gt; — REJECT-паттерны:&lt;br/&gt;• crowded scene: &#39;multiple/several/crowd/group of 3-9 people&#39;&lt;br/&gt;• too many limbs: &#39;six/seven+ people/hands/arms&#39;&lt;br/&gt;• contradictory camera: &#39;zoom in&#39; + &#39;pan/tilt/dolly&#39;&lt;br/&gt;• contradictory pace: &#39;slow motion&#39; + &#39;fast-paced/rapid&#39;&lt;br/&gt;• conflicting actions: &#39;dancing and fighting&#39;&lt;br/&gt;→ любой REJECT = REROLL" vertex="1">
          <mxGeometry height="115" width="700" x="990" y="730" as="geometry" />
        </mxCell>
        <mxCell id="p6b5c" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11;arcSize=10;" value="&lt;b&gt;WARN-паттерны&lt;/b&gt;&lt;br/&gt;(не блокируют, только логируют):&lt;br/&gt;• vague qualifiers: beautiful/stunning/amazing&lt;br/&gt;• hand detail: hands/fingers holding/touching&lt;br/&gt;→ промпт принимается, WARNING в лог" vertex="1">
          <mxGeometry height="105" width="365" x="1730" y="735" as="geometry" />
        </mxCell>
        <mxCell id="p6b6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=11;arcSize=10;" value="&lt;b&gt;saveFingerprint(db, fingerprint, streamId, jobId, brief)&lt;/b&gt;&lt;br/&gt;src/prompts/fingerprint.ts&lt;br/&gt;&lt;br/&gt;INSERT OR IGNORE INTO prompt_fingerprints (fingerprint, stream_id, job_id, created_at, theme, subject, action, environment, camera)&lt;br/&gt;INSERT OR IGNORE = идемпотентно (повтор сообщения из очереди не создаст дубль)&lt;br/&gt;Все 8 полей brief сохраняются для будущего аудита и отладки" vertex="1">
          <mxGeometry height="110" width="1440" x="190" y="880" as="geometry" />
        </mxCell>
        <mxCell id="p6b7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=11;arcSize=10;" value="✅ &lt;b&gt;Уникальный, валидный промпт принят&lt;/b&gt;&lt;br/&gt;Возвращается в generatePromptBatch() → записывается в job.prompt_text → передаётся GPU worker-у через /jobs/claim&lt;br/&gt;Fingerprint заблокирует этот визуальный концепт для ВСЕХ будущих стримов на данной платформе." vertex="1">
          <mxGeometry height="100" width="1440" x="200" y="1040" as="geometry" />
        </mxCell>
        <mxCell id="p6rer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=11;arcSize=10;" value="↻ &lt;b&gt;REROLL&lt;/b&gt;&lt;br/&gt;MAX_REROLLS = 4&lt;br/&gt;попыток на слот&lt;br/&gt;&lt;br/&gt;При провале:&lt;br/&gt;attempt++ и заново&lt;br/&gt;с generateBrief()&lt;br/&gt;&lt;br/&gt;Если все 4 провалились:&lt;br/&gt;слот пропускается,&lt;br/&gt;стрим получит&lt;br/&gt;меньше видео" vertex="1">
          <mxGeometry height="540" width="155" x="2520" y="285" as="geometry" />
        </mxCell>
