        <mxCell id="p4s0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#94a3b8;fontSize=10;arcSize=4;verticalAlign=middle;" value="Аренда" vertex="1">
          <mxGeometry height="60" width="52.46666666666667" x="40" y="305" as="geometry" />
