        <mxCell id="p7e0a" edge="1" parent="1" source="p7p0a" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p7p0b" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7e0b" edge="1" parent="1" source="p7p0b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p7p0c" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7e0c" edge="1" parent="1" source="p7p0c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p7p0d" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7e0d" edge="1" parent="1" source="p7p0d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p7p0e" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7e0e" edge="1" parent="1" source="p7p0e" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p7p0f" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p7ph1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#c4b5fd;fontSize=13;fontStyle=1;fontColor=#5b21b6;verticalAlign=top;arcSize=3;" value="PHASE 1: Генерация промптов батчами (параллельно с cold start GPU)" vertex="1">
          <mxGeometry height="270" width="1574" x="40" y="248" as="geometry" />
        </mxCell>
        <mxCell id="p7b0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#a855f7;fontSize=11;arcSize=10;" value="&lt;b&gt;Batch 0&lt;/b&gt; (seq 1–50)&lt;br/&gt;batch_index=0&lt;br/&gt;&lt;br/&gt;① generateBrief() × 50 → Gemini API&lt;br/&gt;② computeFingerprint() × 50 → SHA-256&lt;br/&gt;③ isDuplicate() × 50 → D1&lt;br/&gt;④ renderPrompt() × 50 → Gemini API&lt;br/&gt;⑤ validate × 50 → regex&lt;br/&gt;⑥ 50 INSERT jobs в D1&lt;br/&gt;⑦ 50 render-queue.send()&lt;br/&gt;⑧ stream-queue.send(batch_index=1)" vertex="1">
          <mxGeometry height="210" width="290" x="65" y="288" as="geometry" />
        </mxCell>
        <mxCell id="p7b1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#a855f7;fontSize=11;arcSize=10;" value="&lt;b&gt;Batch 1&lt;/b&gt; (seq 51–100)&lt;br/&gt;batch_index=1&lt;br/&gt;&lt;br/&gt;100 Gemini API calls&lt;br/&gt;50 D1 fingerprint checks&lt;br/&gt;50 D1 job inserts&lt;br/&gt;50 render-queue msgs&lt;br/&gt;+ stream-queue.send(batch_index=2)&lt;br/&gt;&lt;br/&gt;&lt;i&gt;И так далее каждый batch...&lt;/i&gt;" vertex="1">
          <mxGeometry height="210" width="240" x="375" y="288" as="geometry" />
        </mxCell>
        <mxCell id="p7bdots" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;" value="…" vertex="1">
          <mxGeometry height="80" width="40" x="625" y="370" as="geometry" />
        </mxCell>
        <mxCell id="p7b19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#a855f7;fontSize=11;arcSize=10;" value="&lt;b&gt;Batch 19&lt;/b&gt; (seq 951–1000)&lt;br/&gt;batch_index=19&lt;br/&gt;&lt;br/&gt;Последний батч&lt;br/&gt;remaining=50&lt;br/&gt;&lt;br/&gt;50 jobs → D1&lt;br/&gt;50 render-queue msgs&lt;br/&gt;&lt;b&gt;НЕТ&lt;/b&gt; след. stream-queue msg&lt;br/&gt;(remaining=0 после этого)" vertex="1">
          <mxGeometry height="210" width="265" x="680" y="288" as="geometry" />
        </mxCell>
        <mxCell id="p7bs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;fontSize=11;arcSize=6;" value="&lt;b&gt;Итого по батчам:&lt;/b&gt;&lt;br&gt;20 батчей × 50 видео = 1000 видео&lt;br&gt;20 батчей × 100 Gemini calls = 2000 API-вызовов&lt;br&gt;1000 jobs в D1 (state=&#39;pending&#39;)&lt;br&gt;1000 сообщений в render-queue&lt;br&gt;Батчи обрабатываются последовательно (~CF Worker 30с/батч)" vertex="1">
          <mxGeometry height="165" width="640" x="960" y="290" as="geometry" />
        </mxCell>
        <mxCell id="p7qn" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;fontSize=11;arcSize=6;" value="&lt;b&gt;Очереди в этой фазе:&lt;/b&gt;&lt;br/&gt;stream-queue → batch_index 0,1,2...19 (chain)&lt;br/&gt;render-queue → 1000 job messages&lt;br/&gt;publish-queue → пусто (будет наполняться позже)" vertex="1">
